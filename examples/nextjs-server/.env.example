# TON network: "testnet" or "mainnet"
TON_NETWORK=testnet

# Your wallet address (where you receive payments)
PAYMENT_ADDRESS=your_ton_wallet_address_here

# Jetton master contract address (BSA USD on testnet)
JETTON_MASTER_ADDRESS=kQCd6G7c_HUBkgwtmGzpdqvHIQoNkYOEE0kSWoc5v57hPPnW

# Facilitator URL (You can use the BSA Facilitator if you don't want to run your own)
#FACILITATOR_URL=http://localhost:3000/api/facilitator
FACILITATOR_URL=https://your-vercel-url.vercel.app/api/facilitator

# TON RPC (get a free API key at https://toncenter.com)
TON_RPC_URL=https://testnet.toncenter.com/api/v2/jsonRPC
RPC_API_KEY=your_toncenter_api_key_here

NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app
NEXT_PUBLIC_TON_NETWORK=testnet

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Client wallet mnemonic (24 words), used by the client-script to pay endpoints
# Get a testnet wallet on Tonkeeper (switch to testnet mode)
WALLET_MNEMONIC="word1 word2 word3 ... word24"
